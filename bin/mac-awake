#!/bin/bash
set -euo pipefail

PIDFILE="${MAC_AWAKE_PIDFILE:-$HOME/.mac-awake.pid}"
LOGFILE="${MAC_AWAKE_LOGFILE:-/tmp/mac-awake.log}"
TIMER_PIDFILE="${MAC_AWAKE_TIMER_PIDFILE:-$HOME/.mac-awake.timer.pid}"
TIMER_DEADLINE="${MAC_AWAKE_TIMER_DEADLINE:-$HOME/.mac-awake.timer.deadline}"
SUDOERS_FILE="/private/etc/sudoers.d/mac-awake"

# Absolute path to this script, so the background timer can re-invoke `off`.
SELF="$0"
case "$SELF" in
  */*) ;;
  *) SELF="$(command -v "$SELF" 2>/dev/null || echo "$SELF")" ;;
esac
SELF="$(cd "$(dirname "$SELF")" 2>/dev/null && pwd)/$(basename "$SELF")"

usage() {
  cat <<'EOF'
Usage:
  mac-awake on [minutes]   stay awake; with minutes, auto-sleep after that long
  mac-awake off
  mac-awake status
EOF
}

require_macos() {
  [ "$(uname -s)" = "Darwin" ] || {
    echo "mac-awake: macOS only" >&2
    exit 1
  }
}

shell_escape_for_applescript() {
  /usr/bin/sed 's/\\/\\\\/g; s/"/\\"/g'
}

run_admin_shell() {
  local command="$1"
  local escaped
  escaped="$(printf '%s' "$command" | shell_escape_for_applescript)"
  /usr/bin/osascript -e "do shell script \"$escaped\" with administrator privileges"
}

install_passwordless_pmset() {
  local user script
  user="$(id -un)"
  script="$(/usr/bin/mktemp /tmp/mac-awake-sudoers.XXXXXX)"

  case "$user" in
    *[!A-Za-z0-9_.-]*|"")
      echo "mac-awake: unsupported username for sudoers: $user" >&2
      exit 1
      ;;
  esac

  /bin/cat > "$script" <<EOF
#!/bin/bash
set -euo pipefail

user="$user"
file="$SUDOERS_FILE"
sudoers_tmp="\$(/usr/bin/mktemp /tmp/mac-awake-sudoers-entry.XXXXXX)"
sudoers_backup="/private/etc/sudoers.mac-awake.bak"

/bin/mkdir -p /private/etc/sudoers.d

/bin/cat > "\$sudoers_tmp" <<SUDOERS
# mac-awake: allow one user to toggle lid-close no-sleep without repeated prompts.
\$user ALL=(root) NOPASSWD: /usr/bin/pmset -a disablesleep 1, /usr/bin/pmset -a disablesleep 0
SUDOERS

/usr/sbin/visudo -cf "\$sudoers_tmp" >/dev/null
/usr/sbin/chown root:wheel "\$sudoers_tmp"
/bin/chmod 0440 "\$sudoers_tmp"
/bin/mv "\$sudoers_tmp" "\$file"

if ! /usr/bin/grep -Eq '^[#@]includedir[[:space:]]+/private/etc/sudoers.d' /private/etc/sudoers; then
  /bin/cp /private/etc/sudoers "\$sudoers_backup"
  /bin/printf '\\n#includedir /private/etc/sudoers.d\\n' >> /private/etc/sudoers
  if ! /usr/sbin/visudo -c >/dev/null; then
    /bin/cp "\$sudoers_backup" /private/etc/sudoers
    exit 1
  fi
fi

/usr/sbin/visudo -c >/dev/null
EOF

  /bin/chmod +x "$script"
  echo "Installing one-time passwordless pmset permission for $user..."
  run_admin_shell "/bin/bash $script"
  /bin/rm -f "$script"
}

pmset_disablesleep() {
  local value="$1"

  if [ "$(id -u)" -eq 0 ]; then
    /usr/bin/pmset -a disablesleep "$value"
  elif /usr/bin/sudo -n /usr/bin/pmset -a disablesleep "$value" 2>/dev/null; then
    return 0
  else
    install_passwordless_pmset
    /usr/bin/sudo -n /usr/bin/pmset -a disablesleep "$value"
  fi
}

sleep_disabled_value() {
  /usr/bin/pmset -g live | /usr/bin/awk '$1=="SleepDisabled"{print $2}'
}

pidfile_pid() {
  [ -f "$PIDFILE" ] && /bin/cat "$PIDFILE" || true
}

caffeinate_running() {
  local pid
  pid="$(pidfile_pid)"
  [ -n "$pid" ] && /bin/ps -p "$pid" >/dev/null 2>&1
}

stop_caffeinate() {
  local pid
  pid="$(pidfile_pid)"
  if [ -n "$pid" ]; then
    /bin/kill "$pid" 2>/dev/null || true
  fi
  /bin/rm -f "$PIDFILE"
}

timer_pid() {
  [ -f "$TIMER_PIDFILE" ] && /bin/cat "$TIMER_PIDFILE" || true
}

timer_running() {
  local pid
  pid="$(timer_pid)"
  [ -n "$pid" ] && /bin/ps -p "$pid" >/dev/null 2>&1
}

cancel_timer() {
  local pid
  pid="$(timer_pid)"
  # Remove state first so a watcher that wakes mid-cancel sees it is no
  # longer the active timer and exits without firing `off`.
  /bin/rm -f "$TIMER_PIDFILE" "$TIMER_DEADLINE"
  if [ -n "$pid" ]; then
    /usr/bin/pkill -P "$pid" 2>/dev/null || true
    /bin/kill "$pid" 2>/dev/null || true
  fi
}

start_timer() {
  local minutes="$1" deadline
  cancel_timer
  # Compute and record the deadline here so `status` is correct immediately,
  # without racing the background watcher's startup.
  deadline=$(( $(/bin/date +%s) + minutes * 60 ))
  echo "$deadline" > "$TIMER_DEADLINE"
  /usr/bin/nohup "$SELF" __timer "$deadline" >>"$LOGFILE" 2>&1 &
  echo $! > "$TIMER_PIDFILE"
}

# Background watcher: wait out the countdown, then turn sleep back on.
# Re-checks the pidfile each tick so `cancel_timer` (or a newer timer) can
# retire it cleanly without it ever calling `off`.
timer_run() {
  local deadline="$1" now

  while :; do
    now="$(/bin/date +%s)"
    [ "$now" -ge "$deadline" ] && break
    /bin/sleep 5
    # Superseded or cancelled: another invocation owns the timer now.
    [ "$(timer_pid)" = "$$" ] || exit 0
  done

  # We are about to fire; drop our own state so `off`'s cancel_timer is a no-op
  # and never kills this still-running process before it finishes.
  /bin/rm -f "$TIMER_PIDFILE" "$TIMER_DEADLINE"
  "$SELF" off >>"$LOGFILE" 2>&1
}

on() {
  require_macos
  local minutes="${1:-}"

  if [ -n "$minutes" ]; then
    case "$minutes" in
      ''|*[!0-9]*)
        echo "mac-awake: minutes must be a positive whole number" >&2
        exit 2
        ;;
    esac
    [ "$minutes" -ge 1 ] || {
      echo "mac-awake: minutes must be at least 1" >&2
      exit 2
    }
  fi

  cancel_timer
  stop_caffeinate
  pmset_disablesleep 1

  /usr/bin/nohup /usr/bin/caffeinate -dimsu >"$LOGFILE" 2>&1 &
  echo $! > "$PIDFILE"

  if [ "$(sleep_disabled_value)" = "1" ] && caffeinate_running; then
    if [ -n "$minutes" ]; then
      start_timer "$minutes"
      echo "ON verified (auto-off in ${minutes}m)"
    else
      echo "ON verified"
    fi
  else
    echo "ON failed verification" >&2
    status >&2
    exit 1
  fi
}

off() {
  require_macos
  cancel_timer
  stop_caffeinate
  pmset_disablesleep 0

  if [ "$(sleep_disabled_value)" = "0" ]; then
    echo "OFF verified"
  else
    echo "OFF failed verification" >&2
    status >&2
    exit 1
  fi
}

status() {
  require_macos
  local sleep_disabled pid
  sleep_disabled="$(sleep_disabled_value)"
  pid="$(pidfile_pid)"

  echo "SleepDisabled ${sleep_disabled:-unknown}"
  if caffeinate_running; then
    echo "caffeinate running pid=$pid"
  else
    echo "caffeinate off"
  fi

  if timer_running && [ -f "$TIMER_DEADLINE" ]; then
    local deadline now remaining
    deadline="$(/bin/cat "$TIMER_DEADLINE")"
    now="$(/bin/date +%s)"
    remaining=$(( deadline - now ))
    if [ "$remaining" -gt 0 ]; then
      echo "auto-off in $(( remaining / 60 ))m $(( remaining % 60 ))s"
    fi
  else
    echo "timer off"
  fi
}

case "${1:-}" in
  on) shift; on "$@" ;;
  off) off ;;
  status) status ;;
  __timer) require_macos; timer_run "${2:-}" ;;
  -h|--help|help|"") usage ;;
  *) usage >&2; exit 2 ;;
esac
